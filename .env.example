# OpenAI-compatible API credentials.
# Point OPENAI_BASE_URL at any OpenAI-compatible endpoint:
#   - OpenAI:        https://api.openai.com/v1
#   - Ollama:        http://localhost:11434/v1
#   - vLLM (local):  http://localhost:8000/v1
#   - Together/Groq/etc.: provider-specific URL
OPENAI_API_KEY=sk-replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

# Where the wiki workspace lives (relative paths are resolved from CWD).
WORKSPACE_DIR=./workspace

# Safety cap on the agentic ingest/lint loop.
MAX_TOOL_ITERATIONS=25
